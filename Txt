local function round(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius)
    corner.Parent = parent
    return corner
end

-- ====================================================================
-- 1. HÀM TẠO THÔNG BÁO (NOTIFICATION SYSTEM)
-- ====================================================================
local function showNotification(title, desc, leftIconType, customIcon)
    local Notif = Instance.new("Frame")
    Notif.Name = "CustomNotification"
    Notif.Size = UDim2.new(0, 260, 0, 56)
    Notif.Position = UDim2.new(1, 280, 0.75, 0)
    Notif.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
    Notif.BorderSizePixel = 0
    Notif.ZIndex = 100 
    Notif.Parent = SG
    round(Notif, 14)

    local LeftZone = Instance.new("Frame")
    LeftZone.Size = UDim2.new(0, 40, 1, 0)
    LeftZone.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    LeftZone.BorderSizePixel = 0
    LeftZone.ZIndex = 101
    LeftZone.Visible = (leftIconType ~= nil)
    LeftZone.Parent = Notif
    
    local LeftCorner = Instance.new("UICorner")
    LeftCorner.CornerRadius = UDim.new(0, 14)
    LeftCorner.Parent = LeftZone
    
    local Cover = Instance.new("Frame")
    Cover.Size = UDim2.new(0, 10, 1, 0)
    Cover.Position = UDim2.new(1, -10, 0, 0)
    Cover.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Cover.BorderSizePixel = 0
    Cover.ZIndex = 101
    Cover.Parent = LeftZone

    if leftIconType == "image" then
        local Img = Instance.new("ImageLabel")
        Img.Size = UDim2.new(0, 18, 0, 18)
        Img.Position = UDim2.new(0.5, -9, 0.5, -9)
        Img.BackgroundTransparency = 1
        Img.Image = customIcon
        Img.ZIndex = 102
        Img.Parent = LeftZone
    elseif leftIconType == "text" then
        local Txt = Instance.new("TextLabel")
        Txt.Size = UDim2.new(0, 18, 0, 18)
        Txt.Position = UDim2.new(0.5, -9, 0.5, -9)
        Txt.BackgroundTransparency = 1
        Txt.Text = customIcon
        Txt.TextColor3 = Color3.fromRGB(255, 255, 255)
        Txt.Font = Enum.Font.GothamBold
        Txt.TextSize = 14
        Txt.ZIndex = 102
        Txt.Parent = LeftZone
    end

    local N_Title = Instance.new("TextLabel")
    N_Title.Size = UDim2.new(0, 170, 0, 16)
    N_Title.Position = UDim2.new(0, (leftIconType and 50 or 16), 0, 10)
    N_Title.BackgroundTransparency = 1
    N_Title.Text = title
    N_Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    N_Title.Font = Enum.Font.GothamBold
    N_Title.TextSize = 12
    N_Title.TextXAlignment = Enum.TextXAlignment.Left
    N_Title.ZIndex = 101
    N_Title.Parent = Notif

    local N_Desc = Instance.new("TextLabel")
    N_Desc.Size = UDim2.new(0, 170, 0, 14)
    N_Desc.Position = UDim2.new(0, (leftIconType and 50 or 16), 0, 28)
    N_Desc.BackgroundTransparency = 1
    N_Desc.Text = desc
    N_Desc.TextColor3 = Color3.fromRGB(170, 170, 175)
    N_Desc.Font = Enum.Font.GothamMedium
    N_Desc.TextSize = 10
    N_Desc.TextXAlignment = Enum.TextXAlignment.Left
    N_Desc.ZIndex = 101
    N_Desc.Parent = Notif

    local C_Btn = Instance.new("TextButton")
    C_Btn.Size = UDim2.new(0, 14, 0, 14)
    C_Btn.Position = UDim2.new(1, -22, 0, 10)
    C_Btn.BackgroundTransparency = 1
    C_Btn.Text = "✕"
    C_Btn.TextColor3 = Color3.fromRGB(150, 150, 155)
    C_Btn.TextSize = 11
    C_Btn.Font = Enum.Font.GothamBold
    C_Btn.ZIndex = 102
    C_Btn.Parent = Notif

    local ProgressBar = Instance.new("Frame")
    ProgressBar.Size = UDim2.new(1, 0, 0, 2.5)
    ProgressBar.Position = UDim2.new(0, 0, 1, -2.5)
    ProgressBar.BackgroundColor3 = Color3.fromRGB(168, 85, 247)
    ProgressBar.BorderSizePixel = 0
    ProgressBar.ZIndex = 101
    ProgressBar.Parent = Notif
    round(ProgressBar, 1)

    TweenService:Create(Notif, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -275, 0.75, 0)}):Play()

    local barTween = TweenService:Create(ProgressBar, TweenInfo.new(3, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 2.5)})
    barTween:Play()

    C_Btn.MouseButton1Click:Connect(function() Notif:Destroy() end)

    barTween.Completed:Connect(function()
        local fadeTween = TweenService:Create(Notif, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            BackgroundTransparency = 1,
            Position = UDim2.new(1, 280, 0.75, 0)
        })
        TweenService:Create(LeftZone, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        TweenService:Create(Cover, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        TweenService:Create(N_Title, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(N_Desc, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(C_Btn, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        
        fadeTween:Play()
        fadeTween.Completed:Connect(function() Notif:Destroy() end)
    end)
end

