local function createFeatureCard(name, desc, iconId, isTextIcon, positionY, onClickFunc)
    local Card = Instance.new("Frame")
    Card.Size = UDim2.new(0, 250, 0, 38)
    Card.Position = UDim2.new(0, 155, 0, positionY)
    Card.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
    Card.BackgroundTransparency = 0.4
    Card.BorderSizePixel = 0
    Card.ZIndex = 10 
    Card.Parent = MainMenu
    round(Card, 8)

    local T_Name = Instance.new("TextLabel")
    T_Name.Size = UDim2.new(1, -40, 0, 16)
    T_Name.Position = UDim2.new(0, 12, 0, 4)
    T_Name.BackgroundTransparency = 1
    T_Name.Text = name
    T_Name.TextColor3 = Color3.fromRGB(255, 255, 255)
    T_Name.Font = Enum.Font.GothamBold
    T_Name.TextSize = 10
    T_Name.TextXAlignment = Enum.TextXAlignment.Left
    T_Name.ZIndex = 11
    T_Name.Parent = Card

    local T_Desc = Instance.new("TextLabel")
    T_Desc.Size = UDim2.new(1, -40, 0, 14)
    T_Desc.Position = UDim2.new(0, 12, 0, 18)
    T_Desc.BackgroundTransparency = 1
    T_Desc.Text = desc
    T_Desc.TextColor3 = Color3.fromRGB(145, 145, 150)
    T_Desc.Font = Enum.Font.Gotham
    T_Desc.TextSize = 8
    T_Desc.TextXAlignment = Enum.TextXAlignment.Left
    T_Desc.ZIndex = 11
    T_Desc.Parent = Card

    local RightIcon
    if isTextIcon then
        RightIcon = Instance.new("TextLabel")
        RightIcon.Text = iconId
        RightIcon.TextColor3 = Color3.fromRGB(150, 150, 155)
        RightIcon.TextSize = 11
        RightIcon.Font = Enum.Font.GothamBold
    else
        RightIcon = Instance.new("ImageLabel")
        RightIcon.Image = iconId
        RightIcon.ImageColor3 = Color3.fromRGB(150, 150, 155)
    end
    RightIcon.Size = UDim2.new(0, 14, 0, 14)
    RightIcon.Position = UDim2.new(1, -24, 0.5, -7)
    RightIcon.BackgroundTransparency = 1
    RightIcon.ZIndex = 11
    RightIcon.Parent = Card

    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.BackgroundTransparency = 1
    Btn.Text = ""
    Btn.ZIndex = 12
    Btn.Parent = Card

    local active = false
    Btn.MouseButton1Click:Connect(function()
        active = not active
        Card.BackgroundColor3 = active and Color3.fromRGB(35, 42, 53) or Color3.fromRGB(24, 24, 28)
        if onClickFunc then onClickFunc() end
    end)
end

